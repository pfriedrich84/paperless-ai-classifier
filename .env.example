# =============================================================================
# paperless-ai-classifier — Environment Configuration
# =============================================================================
# Copy to .env and fill in the required values.

# --- Paperless-NGX (required) ------------------------------------------------
PAPERLESS_URL=http://paperless:8000
PAPERLESS_TOKEN=your-api-token-here
PAPERLESS_INBOX_TAG_ID=1
# Optional: Tag ID to add after commit (e.g. "Verarbeitet")
# PAPERLESS_PROCESSED_TAG_ID=
# Keep the inbox tag (Posteingang) on documents after commit (default: true)
KEEP_INBOX_TAG=true

# --- Ollama -------------------------------------------------------------------
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_TIMEOUT_SECONDS=300
# Retry settings for embedding requests (context-length truncation + transient 500s)
OLLAMA_EMBED_RETRIES=3
OLLAMA_EMBED_RETRY_BASE_DELAY=1.0
# Context window size for the chat model (tokens). Prompt is budgeted to fit.
# gemma3 e4b supports 128K; 8192 is a good balance of quality vs VRAM usage.
OLLAMA_NUM_CTX=8192

# --- Worker -------------------------------------------------------------------
POLL_INTERVAL_SECONDS=300
CONTEXT_MAX_DOCS=5
MAX_DOC_CHARS=8000
# 0 = always require manual review. Set to e.g. 85 to auto-commit high-confidence results.
AUTO_COMMIT_CONFIDENCE=0
ENABLE_OCR_CORRECTION=false

# --- GUI ----------------------------------------------------------------------
GUI_PORT=8088
# External base URL for links in Telegram messages (e.g. https://classifier.local:8088)
# Leave empty to default to http://localhost:GUI_PORT
GUI_BASE_URL=
# Leave empty to disable Basic Auth
GUI_USERNAME=
GUI_PASSWORD=

# --- Telegram (optional) -----------------------------------------------------
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL=5

# --- Webhook ------------------------------------------------------------------
# Shared secret for POST /webhook/paperless. Leave empty for no auth.
# If set, callers must send: X-Webhook-Secret: <value>
WEBHOOK_SECRET=

# --- MCP Server (optional) ---------------------------------------------------
# Set ENABLE_MCP=true to start the MCP SSE server alongside the main app
# (same container, no extra service needed).
ENABLE_MCP=false
# MCP_TRANSPORT=sse            # sse | streamable-http (stdio only for local CLI)
# MCP_PORT=3001
# MCP_HOST=0.0.0.0
# MCP_ENABLE_WRITE=false       # set to true to enable write tools
# MCP_API_KEY=                  # set to require auth (recommended for SSE)
# MCP_CLASSIFY_RATE_LIMIT=10   # max AI classifications per hour, 0=unlimited

# --- Storage / Logging --------------------------------------------------------
DATA_DIR=/data
LOG_LEVEL=INFO
