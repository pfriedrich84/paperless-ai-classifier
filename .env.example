# =============================================================================
# ArchiBot — Environment Configuration
# =============================================================================
# Copy to .env and fill in the required values.

# --- Docker Image -------------------------------------------------------------
# Image tag to use (e.g. latest, v1.2.0, sha-abc1234)
# IMAGE_TAG=latest

# --- Paperless-NGX (required) ------------------------------------------------
PAPERLESS_URL=http://paperless:8000
PAPERLESS_TOKEN=your-api-token-here
PAPERLESS_INBOX_TAG_ID=1
# Optional: Tag ID to add after commit (e.g. "Verarbeitet")
# PAPERLESS_PROCESSED_TAG_ID=
# Keep the inbox tag (Posteingang) on documents after commit (default: true)
KEEP_INBOX_TAG=true

# --- Ollama -------------------------------------------------------------------
OLLAMA_URL=http://ollama:11434
# Classification model (recommended on 6GB: gemma4:e4b)
# Alternatives to try: qwen3:4b, llama3.1:8b (if VRAM/offload allows)
OLLAMA_MODEL=gemma4:e4b
# 6GB VRAM recommendation: stronger embedding model for better retrieval quality
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
# Embedding vector dimension for sqlite-vec. 0 = auto-detect known defaults
# (qwen3-embedding:0.6b -> 1024, qwen3-embedding:4b -> 2560)
OLLAMA_EMBED_DIM=0
# 6GB VRAM recommendation for text-only OCR correction (used when OCR_MODE=text)
OLLAMA_OCR_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=600
# Retry settings for embedding requests (context-length truncation + transient 500s)
OLLAMA_EMBED_RETRIES=3
OLLAMA_EMBED_RETRY_BASE_DELAY=1.0
# Retry settings for chat/classification/OCR requests (transient 429/5xx/timeouts)
OLLAMA_CHAT_RETRIES=2
OLLAMA_CHAT_RETRY_BASE_DELAY=1.0
# Context window size for the chat model (tokens). Prompt is budgeted to fit.
# For gemma4:e4b, 16384 is a good balance of quality vs VRAM usage.
OLLAMA_NUM_CTX=16384
# Context window for embedding model. qwen3-embedding:4b can use long context,
# 8192 is a good balance of quality vs throughput.
OLLAMA_EMBED_NUM_CTX=8192
# Context window for OCR correction model. 12288 helps fit 4b OCR workloads on 6GB GPUs.
OLLAMA_OCR_NUM_CTX=12288
# Seconds to wait after unloading a model before loading the next one.
# Helps Ollama detect correct free VRAM on GPUs with slow memory recovery.
# Set to 0 to disable. Default: 8
# OLLAMA_MODEL_SWAP_DELAY=8

# --- Worker -------------------------------------------------------------------
POLL_INTERVAL_SECONDS=300
CONTEXT_MAX_DOCS=5
MAX_DOC_CHARS=24000
# Max characters of document text used for embedding/similarity search (default: 6000)
# EMBED_MAX_CHARS=6000
# 0 = always require manual review. Set to e.g. 85 to auto-commit high-confidence results.
AUTO_COMMIT_CONFIDENCE=0
# Optional LLM-as-judge second pass: verify each classification with another LLM call.
# Only runs when initial confidence is below JUDGE_CONFIDENCE_THRESHOLD.
ENABLE_JUDGE_VERIFICATION=false
JUDGE_CONFIDENCE_THRESHOLD=85
# Leave empty to reuse OLLAMA_MODEL (no extra GPU model swap).
OLLAMA_JUDGE_MODEL=
# OCR correction mode: off, text, vision_light, vision_full
# 6GB preset uses vision_light for stronger OCR validation.
OCR_MODE=vision_light
OCR_VISION_MODEL=qwen3-vl:4b
OCR_VISION_MAX_PAGES=2
OCR_VISION_DPI=130

# --- GUI ----------------------------------------------------------------------
GUI_PORT=8088
# External base URL for links in Telegram messages (e.g. https://classifier.local:8088)
# Leave empty to default to http://localhost:GUI_PORT
GUI_BASE_URL=
# Date format used in the GUI (Python strftime syntax)
GUI_DATE_FORMAT=%d.%m.%Y
# Leave empty to disable Basic Auth
GUI_USERNAME=
GUI_PASSWORD=

# --- Telegram (optional) -----------------------------------------------------
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL=5

# --- Webhook ------------------------------------------------------------------
# Shared secret for POST /webhook/paperless. Leave empty for no auth.
# If set, callers must send: X-Webhook-Secret: <value>
WEBHOOK_SECRET=

# --- MCP Server (optional) ---------------------------------------------------
# Set ENABLE_MCP=true to start the MCP SSE server alongside the main app
# (same container, no extra service needed).
ENABLE_MCP=false
# MCP_TRANSPORT=sse            # sse | streamable-http (stdio only for local CLI)
# MCP_PORT=3001
# MCP_HOST=0.0.0.0
# MCP_ENABLE_WRITE=false       # set to true to enable write tools
# MCP_API_KEY=                  # set to require auth (recommended for SSE)
# MCP_CLASSIFY_RATE_LIMIT=10   # max AI classifications per hour, 0=unlimited

# --- Storage / Logging --------------------------------------------------------
DATA_DIR=/data
LOG_LEVEL=INFO
